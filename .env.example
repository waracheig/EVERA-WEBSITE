# =============================================================================
# Site
# =============================================================================
# Public site URL — used for sitemap.xml, robots.txt, JSON-LD
NEXT_PUBLIC_SITE_URL=https://evera.asia


# =============================================================================
# Inquiry form delivery (Resend)
# =============================================================================
# Sign up at https://resend.com (free 3,000 emails/month) and create an API key.
# Without this, inquiries are logged to the server console only.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# Where inquiry emails are delivered (sales/ops inbox)
INQUIRY_TO_EMAIL=ev@easynetwork.co.th

# Verified sender — must be a domain you've verified in Resend.
# While testing you can keep "onboarding@resend.dev" (sender shows as Resend test).
# After verifying evera.asia in Resend, set: noreply@evera.asia
INQUIRY_FROM_EMAIL=EvEra Website <onboarding@resend.dev>


# =============================================================================
# Analytics + Search Console
# =============================================================================
# Google Analytics 4 measurement ID. Leave empty to disable.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification token.
# In Search Console: Add property → Verify by HTML tag → copy the
# `content="..."` value into this variable.
# NEXT_PUBLIC_GOOGLE_VERIFICATION=abcdef1234567890
